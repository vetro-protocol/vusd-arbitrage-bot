# ──────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=
PRODUCT=VUSD                  # VUSD or VETBTC

# ──────────────────────────────────────────────────────────────
# Wallet — optional (omit for DRY-RUN: polls + logs, no tx)
# ──────────────────────────────────────────────────────────────
PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────
# Optional address override — only set if arb contract was redeployed
# (REQUIRED for VETBTC until the contract is deployed and products.ts is updated)
# ──────────────────────────────────────────────────────────────
# ARBITRAGE_ADDRESS=

# ──────────────────────────────────────────────────────────────
# DEX aggregator API keys — 1inch + Matcha recommended, LiFi optional
# ──────────────────────────────────────────────────────────────
ONEINCH_API_KEY=
ZEROX_API_KEY=
LIFI_API_KEY=

# ──────────────────────────────────────────────────────────────
# Source toggles (all default true)
# ──────────────────────────────────────────────────────────────
# ENABLE_ONEINCH=false
# ENABLE_ZEROX=false
# ENABLE_LIFI=false
# ENABLE_CURVE_ROUTER=false

# ──────────────────────────────────────────────────────────────
# Tunings — all optional. Defaults from src/products.ts.
# Values are in the product's underlying base asset (USDC / WBTC).
# ──────────────────────────────────────────────────────────────
# MIN_PROFIT_BASE=5                       # VUSD default; VETBTC default 0.0001
# ESTIMATED_GAS_COST_BASE=5               # VUSD default; VETBTC default 0.00006
# MAX_FLASH_AMOUNT=1000000                # human units (1,000,000 USDC for VUSD)
# FLASH_AMOUNT_TIERS=[[500,2000],[200,1000],[50,500],[0,500]]
POLL_INTERVAL_MS=5000
MAX_GAS_PRICE_GWEI=50
SLIPPAGE_BPS=50

# ──────────────────────────────────────────────────────────────
# Deployment only
# ──────────────────────────────────────────────────────────────
# KEEPER_ADDRESS=
# OWNER_ADDRESS=
# KEEPER_SHARE_BPS=0
# ETHERSCAN_API_KEY=