# RPC
ETHEREUM_RPC_URL=
CHAIN_ID=1

# Deployment (used by forge script)
PRIVATE_KEY=
GATEWAY_ADDRESS=
KEEPER_ADDRESS=
TREASURY_ADDRESS=
OWNER_ADDRESS=
KEEPER_SHARE_BPS=0

# Flash loan providers (optional, can be set post-deployment)
AAVE_V3_POOL=0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2
MORPHO_ADDRESS=0xBBBBBbbBBb9cC5e90e3b3Af64bdAF62C37EEFFCb
BALANCER_VAULT=

# Keeper bot
VUSD_ARBITRAGE_ADDRESS=
MIN_PROFIT_USD=5
MAX_FLASH_AMOUNT=1000000000000
POLL_INTERVAL_MS=5000
MAX_GAS_PRICE_GWEI=50
SLIPPAGE_BPS=50

# Token addresses (Ethereum mainnet)
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
VUSD_ADDRESS=

# ──────────────────────────────────────────────────────────────
# DEX Aggregator APIs (each provides quote + swap routes)
# ──────────────────────────────────────────────────────────────

# 1inch (requires API key from https://portal.1inch.dev)
ONEINCH_API_KEY=

# 0x / Matcha (requires API key from https://0x.org/pricing)
ZEROX_API_KEY=

# LiFi (no API key needed, auto-indexes new tokens)
LIFI_ENABLED=false

# ──────────────────────────────────────────────────────────────
# On-chain quoters (fallback when aggregator APIs fail)
# ──────────────────────────────────────────────────────────────

# Uniswap V3 (defaults to Ethereum mainnet contracts)
UNISWAP_V3_QUOTER=0x61fFE014bA17989E743c5F6cB21bF9697530B21e
UNISWAP_V3_ROUTER=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45

# Curve pools (format: poolAddress:vusdIndex:stablecoinIndex)
CURVE_POOL_USDC=
CURVE_POOL_USDT=

# ──────────────────────────────────────────────────────────────
# Enable/disable individual price sources (all enabled by default)
# Set to "false" to disable a source
# ──────────────────────────────────────────────────────────────
ENABLE_ONEINCH=true
ENABLE_ZEROX=true
ENABLE_LIFI=true
ENABLE_UNISWAP_V3=true
ENABLE_CURVE=true
