# ──────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=
PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────
# Deployment only (used by forge script)
# ──────────────────────────────────────────────────────────────
KEEPER_ADDRESS=
OWNER_ADDRESS=
KEEPER_SHARE_BPS=0

# ──────────────────────────────────────────────────────────────
# Keeper bot tuning
# ──────────────────────────────────────────────────────────────
MIN_PROFIT_USD=5
MAX_FLASH_AMOUNT=1000000000000
POLL_INTERVAL_MS=5000
# Flash amount tiers: [[deviationBps, amountUsd], ...]
# Larger deviation → bigger trade. Sorted descending, first match wins.
# Default (low liquidity): [[500,2000],[200,1000],[50,500],[0,500]]
# FLASH_AMOUNT_TIERS=[[500,2000],[200,1000],[50,500],[0,500]]
MAX_GAS_PRICE_GWEI=50
SLIPPAGE_BPS=50

# ──────────────────────────────────────────────────────────────
# DEX aggregator API keys
# ──────────────────────────────────────────────────────────────
ONEINCH_API_KEY=
ZEROX_API_KEY=

# ──────────────────────────────────────────────────────────────
# Per-source enable/disable flags (all default to true)
# Set to "false" to disable a specific price source
# ──────────────────────────────────────────────────────────────
# ENABLE_ONEINCH=false
# ENABLE_ZEROX=false
# ENABLE_LIFI=false
# ENABLE_CURVE_ROUTER=false

# ──────────────────────────────────────────────────────────────
# Curve Router — multi-hop via crvUSD
# Route format: hop1|hop2  (each hop: pool:i:j:swapType:poolType:nCoins)
# Hops define BUY direction (stablecoin → crvUSD → VUSD). Sell is auto-reversed.
# swap_type: 1=exchange | pool_type: 1=stable, 10=stable-ng
# ──────────────────────────────────────────────────────────────
CURVE_ROUTER_ROUTE_USDC=0x4DEcE678ceceb27446b35C672dC7d61F30bAD69E:0:1:1:1:2|0xAFbA5800252530CE71b03Ba2BCa2Dd5aE44a7F3d:1:0:1:10:2
CURVE_ROUTER_ROUTE_USDT=0x390f3595bCa2Df7d23783dFd126427CCeb997BF4:0:1:1:1:2|0xAFbA5800252530CE71b03Ba2BCa2Dd5aE44a7F3d:1:0:1:10:2
